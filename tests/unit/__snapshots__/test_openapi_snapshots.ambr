      '/api/audit-log': dict({
        'get': dict({
          'description': '''
            Return recent audit-log entries. Admin role required.
            
            Filters (all optional, all ANDed):
              * ``actor`` — actor_name or actor_id substring match
              * ``path_prefix`` — startswith match on the resource path
              * ``method`` — exact match (POST/PUT/DELETE/PATCH)
              * ``since`` — ISO-8601 timestamp; entries with ``ts >= since`` only
              * ``limit`` — max records (default 100, capped at 1000)
          ''',
          'operationId': 'list_audit_log_api_audit_log_get',
          'parameters': list([
            dict({
              'in': 'query',
              'name': 'actor',
              'required': False,
              'schema': dict({
                'anyOf': list([
                  dict({
                    'type': 'string',
                  }),
                  dict({
                    'type': 'null',
                  }),
                ]),
                'title': 'Actor',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'path_prefix',
              'required': False,
              'schema': dict({
                'anyOf': list([
                  dict({
                    'type': 'string',
                  }),
                  dict({
                    'type': 'null',
                  }),
                ]),
                'title': 'Path Prefix',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'method',
              'required': False,
              'schema': dict({
                'anyOf': list([
                  dict({
                    'type': 'string',
                  }),
                  dict({
                    'type': 'null',
                  }),
                ]),
                'title': 'Method',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'since',
              'required': False,
              'schema': dict({
                'anyOf': list([
