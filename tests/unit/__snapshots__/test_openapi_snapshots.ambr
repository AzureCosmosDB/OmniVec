    'openapi': '3.1.0',
    'paths': dict({
      '/api/admin/export': dict({
        'get': dict({
          'description': '''
            Export OmniVec deployment data as a JSON bundle.
            
            Query params:
              - include: csv of {sources,destinations,pipelines,models,assistants}
              - include_secrets: if true, keep connection strings / api keys / passwords
              - include_checkpoints: if true, append all (or pipeline-scoped) checkpoints
              - pipeline_ids: csv; when set, only export these pipelines plus the sources,
                destinations, models, and assistants they reference (unless overridden by
                an explicit per-type *_ids filter below)
              - source_ids / destination_ids / model_ids / assistant_ids: csv; when set,
                filter that type to exactly those IDs (overrides pipeline-driven auto
                inclusion for that type)
              - download: if true, send as attachment
          ''',
          'operationId': 'export_bundle_api_admin_export_get',
          'parameters': list([
            dict({
              'in': 'query',
              'name': 'include',
              'required': False,
              'schema': dict({
                'default': 'sources,destinations,pipelines,models,assistants',
                'title': 'Include',
                'type': 'string',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'include_secrets',
              'required': False,
              'schema': dict({
                'default': False,
                'title': 'Include Secrets',
                'type': 'boolean',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'include_checkpoints',
              'required': False,
              'schema': dict({
                'default': False,
                'title': 'Include Checkpoints',
                'type': 'boolean',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'pipeline_ids',
              'required': False,
              'schema': dict({
                'default': '',
                'title': 'Pipeline Ids',
                'type': 'string',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'source_ids',
              'required': False,
              'schema': dict({
                'default': '',
                'title': 'Source Ids',
                'type': 'string',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'destination_ids',
              'required': False,
              'schema': dict({
                'default': '',
                'title': 'Destination Ids',
                'type': 'string',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'model_ids',
              'required': False,
              'schema': dict({
                'default': '',
                'title': 'Model Ids',
                'type': 'string',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'assistant_ids',
              'required': False,
              'schema': dict({
                'default': '',
                'title': 'Assistant Ids',
                'type': 'string',
              }),
            }),
            dict({
              'in': 'query',
              'name': 'download',
              'required': False,
              'schema': dict({
                'default': False,
                'title': 'Download',
                'type': 'boolean',
              }),
            }),
          ]),
          'responses': dict({
            '200': dict({
              'content': dict({
                'application/json': dict({
                  'schema': dict({
                  }),
                }),
              }),
              'description': 'Successful Response',
            }),
            '422': dict({
              'content': dict({
                'application/json': dict({
                  'schema': dict({
                    '$ref': '#/components/schemas/HTTPValidationError',
